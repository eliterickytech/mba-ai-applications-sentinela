# Segredos — NUNCA versionar
.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
build/
dist/

# Quarto (artefatos gerados — PDFs/HTML renderizados)
.quarto/
*_files/
*.pdf
*.html
# Exceção: fundo.html é fonte (include-in-header dos slides), não artefato gerado
!fundo.html

# Exceção: a entrega final renderizada É versionada
!entrega/
!entrega/paper.pdf
!entrega/apresentacao.html

# Dados/saídas geradas
saidas/
*.log

# Sistema
.DS_Store
Thumbs.db
