# Copie este arquivo para ".env" e preencha com suas chaves.
# O .env está no .gitignore e NUNCA deve ir para o git.

# --- NASA NeoWs ---
# Funciona com DEMO_KEY (limite baixo). Gere a sua gratuita em https://api.nasa.gov
NASA_API_KEY=DEMO_KEY

# --- LLM (OpenAI / GPT) ---
# Crie em https://platform.openai.com/api-keys
OPENAI_API_KEY=coloque_sua_chave_aqui

# --- WhatsApp Cloud API (Meta) ---
# developers.facebook.com -> app Business -> produto WhatsApp -> API Setup
WHATSAPP_TOKEN=coloque_o_token_aqui
WHATSAPP_PHONE_NUMBER_ID=coloque_o_phone_number_id
WHATSAPP_DESTINO=numero_com_ddi_ex_5511999999999
